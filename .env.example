# Aegis LLM Configuration
# =======================
# The pipeline uses the LLM for investigation and patching when configured.
# Without these, it falls back to deterministic heuristics (no API key needed).

# 1. Get a free API key from https://console.groq.com/keys
# 2. Copy this file to .env and replace the placeholder below
# 3. The pipeline will auto-load from .env via python-dotenv

AEGIS_LLM_ENDPOINT=https://api.groq.com/openai/v1
AEGIS_LLM_API_KEY=gsk_your_api_key_here
AEGIS_LLM_MODEL=llama-3.3-70b-versatile
